{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "Kilowott Design System",
  "version": "0.6",
  "canonical": "project/styles/tokens.css",
  "description": "Machine-readable token export. Keep in sync with tokens.css.",

  "color": {
    "brand": {
      "ink":       { "value": "#0B0F14", "desc": "near-black · primary text, hero backgrounds" },
      "ink-2":     { "value": "#1A2230", "desc": "secondary dark surface" },
      "ink-3":     { "value": "#2B3544", "desc": "tertiary dark, borders on dark" },
      "paper":     { "value": "#FFFFFF", "desc": "primary surface" },
      "paper-2":   { "value": "#F6F4F0", "desc": "warm off-white, section breaks" },
      "paper-3":   { "value": "#EDEAE3", "desc": "warmer still, cards on paper" },
      "red":       { "value": "#E4022D", "desc": "signature — use sparingly" },
      "red-soft":  { "value": "#FCE5EA", "desc": "tinted bg for red accents" },
      "red-ink":   { "value": "#8A021B", "desc": "darkened red for text on paper" },
      "rule":      { "value": "#1A2230", "desc": "rules / borders on paper" },
      "rule-soft": { "value": "#E2DED6", "desc": "soft divider on paper" },
      "muted":     { "value": "#5B6573", "desc": "secondary text on paper" },
      "muted-dark":{ "value": "#8A95A5", "desc": "secondary text on ink" }
    },
    "semantic": {
      "bg":           { "value": "{color.brand.paper}" },
      "bg-2":         { "value": "{color.brand.paper-2}" },
      "bg-3":         { "value": "{color.brand.paper-3}" },
      "fg":           { "value": "{color.brand.ink}" },
      "fg-2":         { "value": "{color.brand.muted}" },
      "accent":       { "value": "{color.brand.red}" },
      "accent-ink":   { "value": "{color.brand.red-ink}" },
      "rule":         { "value": "{color.brand.rule-soft}" },
      "rule-strong":  { "value": "{color.brand.rule}" }
    },
    "usage-ratio": { "paper": 60, "ink": 30, "red": 5, "muted": 5 },
    "alt-accents": {
      "deeper-red":     "#C8102E",
      "signal-orange":  "#F05A28",
      "electric-blue":  "#1F3CFF",
      "ink-mono":       "#0B0F14"
    }
  },

  "typography": {
    "families": {
      "display": { "stack": "\"Newsreader\", \"Fraunces\", ui-serif, Georgia, serif", "role": "headlines, stat numbers, display" },
      "sans":    { "stack": "\"DM Sans\", \"Inter Tight\", ui-sans-serif, system-ui, sans-serif", "role": "body, UI, buttons" },
      "mono":    { "stack": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, monospace", "role": "numbers in tables, meta, code" }
    },
    "scale": {
      "d1":   { "value": "clamp(3.5rem, 7vw, 6.25rem)",   "px": "56–100", "role": "hero" },
      "d2":   { "value": "clamp(2.75rem, 5.2vw, 4.5rem)", "px": "44–72",  "role": "page title" },
      "d3":   { "value": "clamp(2rem, 3.6vw, 3rem)",      "px": "32–48",  "role": "section head" },
      "h1":   { "value": "2.25rem", "px": 36 },
      "h2":   { "value": "1.5rem",  "px": 24 },
      "h3":   { "value": "1.125rem","px": 18 },
      "body": { "value": "1rem",    "px": 16 },
      "sm":   { "value": "0.875rem","px": 14 },
      "xs":   { "value": "0.75rem", "px": 12, "role": "eyebrow" }
    },
    "line-height": { "tight": 1.04, "snug": 1.2, "body": 1.55 },
    "tracking":    { "eyebrow": "0.18em", "display": "-0.02em" },
    "italic-wonk": { "Newsreader/Fraunces": "font-variation-settings: \"SOFT\" 100, \"WONK\" 1;" }
  },

  "spacing": {
    "base": "8pt",
    "scale": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 24, "6": 32, "7": 48, "8": 64, "9": 96, "10": 128 },
    "section": "calc(var(--s-9) * var(--density))",
    "density": { "compact": 0.7, "comfortable": 1, "spacious": 1.3 }
  },

  "radii":   { "0": 0, "1": 2, "2": 4, "3": 8, "4": 12, "pill": 999 },
  "shadows": {
    "0": "none",
    "1": "0 1px 0 rgba(11,15,20,0.06), 0 1px 2px rgba(11,15,20,0.04)",
    "2": "0 2px 4px rgba(11,15,20,0.06), 0 8px 16px rgba(11,15,20,0.06)",
    "3": "0 4px 8px rgba(11,15,20,0.08), 0 24px 48px rgba(11,15,20,0.10)"
  },

  "layout": {
    "container": "1280px",
    "gutter": "32px",
    "grid-cols": [2, 3, 4, 6],
    "collapse-breakpoint": "900px"
  },

  "themes": {
    "light": { "bg": "{color.brand.paper}", "fg": "{color.brand.ink}" },
    "dark":  { "bg": "{color.brand.ink}",   "fg": "{color.brand.paper}" }
  },

  "icons": {
    "library": "Lucide",
    "canonical-url": "https://lucide.dev/icons",
    "cdn": "https://unpkg.com/lucide@latest/dist/umd/lucide.min.js",
    "html-pattern": "<i data-lucide=\"<name>\"></i>",
    "hydrate-js": "lucide.createIcons({ root })",
    "stroke-width": 1.5,
    "stroke-at-48px-plus": 1.25,
    "canvas": [24, 24],
    "color": "currentColor",
    "license": "ISC"
  }
}
